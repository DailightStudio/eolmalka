# Production base URL
NEXT_PUBLIC_SITE_URL=https://eolmalka.vercel.app

# 환율 — Frankfurter API (https://www.frankfurter.dev) **무키·무료** ECB 기준
# 키 불필요. 키 없이도 USD/KRW · JPY/KRW 실데이터가 흐름.
# 1=네트워크 차단(테스트 결정성 — 합성 폴백만 사용)
FX_OFFLINE=

# (선택) Twelve Data — 유료 플랜에서 forex 지원. 있으면 Frankfurter보다 우선.
TWELVE_DATA_KEY=

# 주유비 — 오피넷 (https://www.opinet.co.kr/api/) 회원가입 후 OpenAPI 사용신청
# 키 없으면 합성 폴백
OPINET_API_KEY=

# 금 — 한국금거래소 / KRX 금시장 (공식 API 한정적 → 스크래핑 검토)
GOLD_API_KEY=

# 항공권 — Skyscanner / Amadeus / Travelpayouts 어필리에이트
SKYSCANNER_API_KEY=
TRAVELPAYOUTS_TOKEN=

# Vercel KV (히트 차트·예측 캐싱 + 푸시 구독 저장)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Web Push (VAPID) — `npx web-push generate-vapid-keys --json` 로 1회 발급
# - public은 클라이언트 구독에 필요 (NEXT_PUBLIC_ 접두사 = 빌드 시 클라에 박힘)
# - private/subject는 서버 발송에만 사용 (절대 노출 금지)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
