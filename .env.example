# Production base URL
NEXT_PUBLIC_SITE_URL=https://eolmalka.vercel.app

# 환율 — 한국은행 ECOS API (https://ecos.bok.or.kr/api)
ECOS_API_KEY=
# 폴백: open exchange rates (https://openexchangerates.org)
OPENEXCHANGE_APP_ID=

# 주유비 — 오피넷 (https://www.opinet.co.kr) 회원가입 후 OpenAPI 신청
OPINET_API_KEY=

# 금 — 한국금거래소 / KRX 금시장 (공식 API 한정적 → 스크래핑 검토)
GOLD_API_KEY=

# 항공권 — Skyscanner / Amadeus / Travelpayouts 어필리에이트
SKYSCANNER_API_KEY=
TRAVELPAYOUTS_TOKEN=

# Vercel KV (히트 차트·예측 캐싱)
KV_REST_API_URL=
KV_REST_API_TOKEN=
