# Expo 환경변수 — EXPO_PUBLIC_* 만 클라이언트 번들에 박힘.
# 그 외 접두사는 빌드 시 무시됨 (보안 키는 절대 클라에 박지 말 것 → 백엔드 사용).

# 오피넷 OpenAPI — https://www.opinet.co.kr/api/ (회원가입 후 신청, 무료)
# 키 없으면 합성 폴백
EXPO_PUBLIC_OPINET_API_KEY=

# (옵션) Frankfurter 오프라인 모드 (1이면 합성만)
EXPO_PUBLIC_FX_OFFLINE=

# (옵션) Twelve Data — 유료 plan에서 forex 지원. 있으면 Frankfurter보다 우선.
EXPO_PUBLIC_TWELVE_DATA_KEY=

# OpenRouter (https://openrouter.ai/keys) — 뉴스 감성 분석.
# ⚠️ EXPO_PUBLIC_*은 클라이언트 번들에 박혀 디컴파일로 노출 가능 — 데모 단계만 사용.
# 운영 전엔 server-agent / Edge Function 프록시 권장.
EXPO_PUBLIC_OPENROUTER_KEY=

# (옵션·권장) Supabase Edge Function 프록시 URL.
# 설정하면 클라에 OPENROUTER 키 노출 없이 프록시 경유 (supabase/functions/news-sentiment/index.ts).
EXPO_PUBLIC_NEWS_PROXY_URL=

# data.go.kr (https://www.data.go.kr) — 각 API마다 별도 신청
# KRX 금시장 종가·오피넷 dailyAvgPrice 등 (인프라 골격은 준비, 호출은 키 받으면)
EXPO_PUBLIC_DATA_GO_KR_KEY=
