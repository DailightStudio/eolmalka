# Production base URL
NEXT_PUBLIC_SITE_URL=https://eolmalka.vercel.app

# 환율 — Frankfurter API (https://www.frankfurter.dev) **무키·무료** ECB 기준
# 키 불필요. 키 없이도 USD/KRW · JPY/KRW 실데이터가 흐름.
# 1=네트워크 차단(테스트 결정성 — 합성 폴백만 사용)
FX_OFFLINE=

# (선택) Twelve Data — 유료 플랜에서 forex 지원. 있으면 Frankfurter보다 우선.
TWELVE_DATA_KEY=

# 주유비 — 오피넷 (https://www.opinet.co.kr) 회원가입 후 OpenAPI 신청
OPINET_API_KEY=

# 금 — 한국금거래소 / KRX 금시장 (공식 API 한정적 → 스크래핑 검토)
GOLD_API_KEY=

# 항공권 — Skyscanner / Amadeus / Travelpayouts 어필리에이트
SKYSCANNER_API_KEY=
TRAVELPAYOUTS_TOKEN=

# Vercel KV (히트 차트·예측 캐싱)
KV_REST_API_URL=
KV_REST_API_TOKEN=
